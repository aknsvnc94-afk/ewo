# Supabase Proje Ayarları (Supabase Dashboard > Settings > API adresinden alınır)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx   # GİZLİ - sadece sunucu tarafında kullanılır, asla client'a sızdırılmaz

# Basit oturum imzalama anahtarı (rastgele uzun bir metin girin)
SESSION_SECRET=degistirilmesi-gereken-uzun-rastgele-bir-anahtar
